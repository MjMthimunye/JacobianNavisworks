<Window x:Class="JacobianNavisworks.MainUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:JacobianNavisworks"
             mc:Ignorable="d" 
             Title="Clash Analysis"
             Height="220" Width="600"
             WindowStartupLocation="CenterScreen"
             ResizeMode="CanResizeWithGrip"
             SizeToContent="Manual"
             Background="#f0f0f0">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Clashes Card -->
            <Border Grid.Column="0" Background="teal" CornerRadius="6" Padding="10,8" Margin="3">
                <StackPanel>
                    <TextBlock Text="TOTAL" Foreground="White" FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock x:Name="TotalClashesText" Foreground="White" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <!-- New Clashes Card -->
            <Border Grid.Column="1" Background="red" CornerRadius="6" Padding="10,8" Margin="3">
                <StackPanel>
                    <TextBlock Text="NEW" Foreground="White" FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock x:Name="NewClashesText" Foreground="White" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Active Clashes Card -->
            <Border Grid.Column="0" Background="DarkOrange" CornerRadius="6" Padding="10,8" Margin="3">
                <StackPanel>
                    <TextBlock Text="ACTIVE" Foreground="White" FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock x:Name="ActiveClashesText" Foreground="White" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <!-- Resolved Clashes Card --> 
            <Border Grid.Column="1" Background="DarkGreen" CornerRadius="6" Padding="10,8" Margin="3">
                <StackPanel>
                    <TextBlock Text="RESOLVED" Foreground="White" FontSize="9" FontWeight="SemiBold" Opacity="0.8"/>
                    <TextBlock x:Name="ResolvedClashesText" Foreground="White" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</Window>
